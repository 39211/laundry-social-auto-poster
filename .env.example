# Defaults are safe: dry-run mode never calls Meta Graph API.
DRY_RUN=true
TIMEZONE=Asia/Taipei
META_GRAPH_API_VERSION=v25.0

# Required before live posting.
META_ACCESS_TOKEN=
FB_PAGE_ID=
IG_USER_ID=

# GitHub Pages base URL, without /docs.
# Example: https://your-github-username.github.io/laundry-social-auto-poster
PUBLIC_IMAGE_BASE_URL=

# Optional. Dry-run skips URL checks unless this is true.
VERIFY_PUBLIC_IMAGE_URL=false
