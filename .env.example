# Defaults are safe: dry-run mode never calls Meta Graph API.
DRY_RUN=true
TIMEZONE=Asia/Taipei
META_GRAPH_API_VERSION=v25.0

# Required before live posting.
META_ACCESS_TOKEN=
FB_PAGE_ID=
IG_USER_ID=

# Public HTTPS site base URL for SEO/AIO/GEO canonical pages, without /docs.
# Example: https://your-github-username.github.io
PUBLIC_SITE_BASE_URL=

# Optional Git remote for mirroring generated docs/ into the user/organization root Pages site.
# Example: https://github.com/your-github-username/your-github-username.github.io.git
PUBLIC_ROOT_PAGES_REPO=

# Public HTTPS asset base URL used for Meta image publishing, without /docs.
# This can be the same as PUBLIC_SITE_BASE_URL, or a separate image host.
# Example: https://your-site.netlify.app
PUBLIC_IMAGE_BASE_URL=

# Optional. Dry-run skips URL checks unless this is true.
VERIFY_PUBLIC_IMAGE_URL=false
